{
    "type": "origins:multiple",
    "badges": [
        {
            "type": "origins:tooltip",
            "sprite": "origins:textures/gui/badge/active.png",
            "text": {
                "translate": "origins.gui.badge.active",
                "with": [
                    {
                        "keybind": "key.otherworldorigins.cantrip_three"
                    }
                ]
            }
        }
    ],
    "invoke": {
        "type": "origins:active_self",
        "key": {
            "key": "key.otherworldorigins.cantrip_three"
        },
        "cooldown": 24000,
        "condition": {
            "type": "otherworldorigins:player_level",
            "comparison": ">=",
            "compare_to": 20
        },
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:modify_resource",
                    "resource": "*:*_timer",
                    "modifier": {
                        "operation": "set_total",
                        "value": 2400
                    }
                },
                {
                    "type": "origins:area_of_effect",
                    "radius": 16,
                    "include_self": true,
                    "bientity_condition": {
                        "type": "origins:or",
                        "conditions": [
                            {
                                "type": "otherworldorigins:allied"
                            },
                            {
                                "type": "origins:target_condition",
                                "condition": {
                                    "type": "otherworldorigins:is_friendly"
                                }
                            }
                        ]
                    },
                    "bientity_action": {
                        "type": "origins:and",
                        "actions": [
                            {
                                "type": "origins:target_action",
                                "action": {
                                    "type": "origins:heal",
                                    "amount": 1000
                                }
                            },
                            {
                                "type": "origins:target_action",
                                "action": {
                                    "type": "otherworldorigins:clear_negative_effects"
                                }
                            }
                        ]
                    }
                },
                {
                    "type": "otherworldorigins:cast_spell",
                    "spell": "irons_spellbooks:fortify",
                    "power_level": 10,
                    "cast_time": 0,
                    "interrupt_mode": "force_complete"
                },
                {
                    "type": "origins:play_sound",
                    "sound": "otherworldorigins:valkyrie_land",
                    "volume": 1.2,
                    "category": "players"
                },
                {
                    "type": "origins:spawn_particles",
                    "particle": "minecraft:flash",
                    "count": 1,
                    "force": true
                },
                {
                    "type": "origins:execute_command",
                    "command": "particle minecraft:end_rod ~ ~1 ~ 1 1 1 0.1 40"
                },
                {
                    "type": "origins:execute_command",
                    "command": "particle minecraft:glow ~ ~1 ~ 1 1 1 0 30"
                },
                {
                    "type": "origins:execute_command",
                    "command": "particle minecraft:enchant ~ ~2 ~ 0.5 1 0.5 1 25"
                }
            ]
        },
        "hud_render": {
            "should_render": true,
            "condition": {
                "type": "origins:resource",
                "resource": "*:*_invoke",
                "compare_to": 0,
                "comparison": ">"
            },
            "sprite_location": "origins:textures/gui/community/spiderkolo/resource_bar_02.png",
            "bar_index": 9
        }
    },
    "timer": {
        "type": "origins:resource",
        "min": 0,
        "max": 2400,
        "start_value": 0,
        "min_action": {
            "type": "otherworldorigins:action_bar_message",
            "message": {
                "translate": "otherworldorigins.holy_nimbus.fade",
                "color": "gray"
            }
        },
        "hud_render": {
            "should_render": true,
            "condition": {
                "type": "origins:resource",
                "resource": "*:*_timer",
                "comparison": ">",
                "compare_to": 0
            },
            "sprite_location": "origins:textures/gui/community/huang/resource_bar_02.png",
            "bar_index": 5
        }
    },
    "tick_timer": {
        "type": "origins:action_over_time",
        "interval": 20,
        "entity_action": {
            "type": "origins:modify_resource",
            "resource": "*:*_timer",
            "modifier": {
                "operation": "add_base_early",
                "value": -20
            }
        }
    },
    "pulse_mend": {
        "type": "origins:action_over_time",
        "interval": 40,
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_timer",
            "comparison": ">",
            "compare_to": 0
        },
        "entity_action": {
            "type": "origins:area_of_effect",
            "radius": 16,
            "include_self": true,
            "bientity_condition": {
                "type": "origins:or",
                "conditions": [
                    {
                        "type": "otherworldorigins:allied"
                    },
                    {
                        "type": "origins:target_condition",
                        "condition": {
                            "type": "otherworldorigins:is_friendly"
                        }
                    }
                ]
            },
            "bientity_action": {
                "type": "origins:and",
                "actions": [
                    {
                        "type": "origins:target_action",
                        "action": {
                            "type": "origins:apply_effect",
                            "effect": {
                                "effect": "minecraft:regeneration",
                                "duration": 60,
                                "amplifier": 1,
                                "show_particles": true,
                                "show_icon": true
                            }
                        }
                    },
                    {
                        "type": "origins:target_action",
                        "action": {
                            "type": "origins:apply_effect",
                            "effect": {
                                "effect": "minecraft:resistance",
                                "duration": 60,
                                "amplifier": 0,
                                "show_particles": true,
                                "show_icon": true
                            }
                        }
                    }
                ]
            }
        }
    },
    "pulse_smite": {
        "type": "origins:action_over_time",
        "interval": 30,
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_timer",
            "comparison": ">",
            "compare_to": 0
        },
        "entity_action": {
            "type": "otherworldorigins:area_of_effect_sequential",
            "radius": 16,
            "include_self": false,
            "application_count": 3,
            "delay_ticks": 6,
            "bientity_condition": {
                "type": "origins:or",
                "inverted": true,
                "conditions": [
                    {
                        "type": "otherworldorigins:allied"
                    },
                    {
                        "type": "origins:target_condition",
                        "condition": {
                            "type": "otherworldorigins:is_friendly"
                        }
                    }
                ]
            },
            "bientity_action": {
                "type": "otherworldorigins:cast_spell",
                "spell": {
                    "spells": [
                        "irons_spellbooks:sunbeam",
                        "irons_spellbooks:wisp",
                        "irons_spellbooks:guiding_bolt"
                    ],
                    "power_level": 5
                },
                "cast_time": 0,
                "interrupt_mode": "force_complete"
            }
        }
    },
    "self_armor": {
        "type": "origins:conditioned_attribute",
        "tick_rate": 20,
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_timer",
            "comparison": ">",
            "compare_to": 0
        },
        "modifier": {
            "attribute": "minecraft:generic.armor",
            "operation": "addition",
            "value": 6
        }
    },
    "pulse_particles": {
        "type": "origins:action_over_time",
        "interval": 10,
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_timer",
            "comparison": ">",
            "compare_to": 0
        },
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:execute_command",
                    "command": "particle minecraft:end_rod ~ ~0.5 ~ 0.8 0.8 0.8 0.03 4"
                },
                {
                    "type": "origins:execute_command",
                    "command": "particle minecraft:glow ~ ~1.5 ~ 0.6 0.4 0.6 0 2"
                }
            ]
        }
    },
    "sleep": {
        "type": "origins:action_on_wake_up",
        "entity_action": {
            "type": "origins:modify_resource",
            "resource": "*:*_invoke",
            "modifier": {
                "operation": "set_total",
                "value": 0
            }
        }
    }
}
