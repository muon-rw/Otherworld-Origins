        "condition": {
            "type": "origins:resource",
            "resource": "*:*_timer",
            "comparison": ">",
            "compare_to": 0
        },
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:execute_command",
                    "command": "particle minecraft:end_rod ~ ~1 ~ 1 1 1 0.05 4"
