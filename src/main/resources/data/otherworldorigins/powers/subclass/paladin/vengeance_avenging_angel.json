{
    "type": "origins:multiple",
    "badges": [
        {
            "type": "origins:tooltip",
            "sprite": "origins:textures/gui/badge/active.png",
            "text": {
                "translate": "origins.gui.badge.active",
                "with": [
                    {
                        "keybind": "key.otherworldorigins.cantrip_three"
                    }
                ]
            }
        }
    ],
    "invoke": {
        "type": "origins:active_self",
        "key": {
            "key": "key.otherworldorigins.cantrip_three"
        },
        "cooldown": 24000,
        "condition": {
            "type": "otherworldorigins:player_level",
            "comparison": ">=",
            "compare_to": 20
        },
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:modify_resource",
                    "resource": "*:*_timer",
                    "modifier": {
                        "operation": "set_total",
                        "value": 2400
                    }
                },
                {
                    "type": "otherworldorigins:cast_spell",
                    "spell": "irons_spellbooks:angel_wing",
                    "power_level": 5,
                    "cast_time": 0,
                    "interrupt_mode": "force_complete"
                },
                {
                    "type": "otherworldorigins:cast_spell",
                    "spell": "irons_spellbooks:haste",
                    "power_level": 5,
                    "cast_time": 0,
                    "interrupt_mode": "force_complete"
                },
                {
                    "type": "otherworldorigins:area_of_effect_sequential",
                    "radius": 16,
                    "include_self": false,
                    "application_count": 5,
                    "delay_ticks": 4,
                    "bientity_condition": {
                        "type": "origins:or",
                        "inverted": true,
                        "conditions": [
                            {
                                "type": "otherworldorigins:allied"
                            },
                            {
                                "type": "origins:target_condition",
                                "condition": {
                                    "type": "otherworldorigins:is_friendly"
                                }
                            }
                        ]
                    },
                    "bientity_action": {
                        "type": "otherworldorigins:cast_spell",
                        "spell": "irons_spellbooks:guiding_bolt",
                        "power_level": 5,
                        "cast_time": 0,
                        "interrupt_mode": "force_complete"
                    }
                },
                {
                    "type": "origins:play_sound",
                    "sound": "otherworldorigins:valkyrie_land",
                    "volume": 1.2,
                    "category": "players"
                },
                {
                    "type": "origins:spawn_particles",
                    "particle": "minecraft:flash",
                    "count": 1,
                    "force": true
                },
                {
                    "type": "origins:execute_command",
                    "command": "particle minecraft:end_rod ~ ~1.5 ~ 1.5 1 1.5 0.1 50"
                },
                {
                    "type": "origins:execute_command",
                    "command": "particle minecraft:firework ~ ~2 ~ 1 1 1 0.1 30"
                },
                {
                    "type": "origins:execute_command",
                    "command": "particle minecraft:cloud ~ ~1 ~ 1 0.5 1 0.05 25"
                }
            ]
        },
        "hud_render": {
            "should_render": true,
            "condition": {
                "type": "origins:resource",
                "resource": "*:*_invoke",
                "compare_to": 0,
                "comparison": ">"
            },
            "sprite_location": "origins:textures/gui/community/spiderkolo/resource_bar_02.png",
            "bar_index": 9
        }
    },
    "timer": {
        "type": "origins:resource",
        "min": 0,
        "max": 2400,
        "start_value": 0,
        "min_action": {
            "type": "otherworldorigins:action_bar_message",
            "message": {
                "translate": "otherworldorigins.avenging_angel.fade",
                "color": "gray"
            }
        },
        "hud_render": {
            "should_render": true,
            "condition": {
                "type": "origins:resource",
                "resource": "*:*_timer",
                "comparison": ">",
                "compare_to": 0
            },
            "sprite_location": "origins:textures/gui/community/huang/resource_bar_02.png",
            "bar_index": 5
        }
    },
    "tick_timer": {
        "type": "origins:action_over_time",
        "interval": 20,
        "entity_action": {
            "type": "origins:modify_resource",
            "resource": "*:*_timer",
            "modifier": {
                "operation": "add_base_early",
                "value": -20
            }
        }
    },
    "pulse_barrage": {
        "type": "origins:action_over_time",
        "interval": 25,
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_timer",
            "comparison": ">",
            "compare_to": 0
        },
        "entity_action": {
