                    "spells": [
                        "irons_spellbooks:guiding_bolt",
                        "irons_spellbooks:sunbeam",
                        "irons_spellbooks:wisp",
                        "gtbcs_geomancy_plus:solar_beam",
                        "gtbcs_geomancy_plus:solar_storm"
                    ],
                    "power_level": 5
                },
                "cast_time": 0,
                "interrupt_mode": "force_complete"
            }
        }
    },
    "pulse_sustain": {
        "type": "origins:action_over_time",
        "interval": 200,
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_timer",
            "comparison": ">",
            "compare_to": 0
        },
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "otherworldorigins:cast_spell",
                    "spell": "irons_spellbooks:angel_wing",
                    "power_level": 5,
                    "cast_time": 0,
                    "interrupt_mode": "force_complete"
                },
                {
                    "type": "otherworldorigins:cast_spell",
                    "spell": "irons_spellbooks:haste",
                    "power_level": 5,
                    "cast_time": 0,
                    "interrupt_mode": "force_complete"
                }
            ]
        }
    },
    "self_speed": {
        "type": "origins:conditioned_attribute",
        "tick_rate": 20,
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_timer",
            "comparison": ">",
            "compare_to": 0
        },
        "modifier": {
            "attribute": "minecraft:generic.movement_speed",
