{
    "type": "origins:multiple",
    "badges": [
        {
            "type": "origins:tooltip",
            "sprite": "origins:textures/gui/badge/active.png",
            "text": {
                "translate": "origins.gui.badge.active",
                "with": [
                    {
                        "keybind": "key.otherworldorigins.cantrip_three"
                    }
                ]
            }
        }
    ],
    "invoke": {
        "type": "origins:active_self",
        "key": {
            "key": "key.otherworldorigins.cantrip_three"
        },
        "cooldown": 24000,
        "condition": {
            "type": "otherworldorigins:player_level",
            "comparison": ">=",
            "compare_to": 20
        },
        "entity_action": {
            "type": "origins:area_of_effect",
            "radius": 16,
            "include_self": true,
            "bientity_condition": {
                "type": "origins:or",
                "conditions": [
                    {
                        "type": "otherworldorigins:allied"
                    },
                    {
                        "type": "origins:target_condition",
                        "condition": {
                            "type": "otherworldorigins:is_friendly"
                        }
                    }
                ]
            },
            "bientity_action": {
                "type": "origins:and",
                "actions": [
                    {
                        "type": "origins:target_action",
                        "action": {
                            "type": "otherworldorigins:restore_mana",
                            "amount": 100000
                        }
                    },
                    {
                        "type": "origins:target_action",
                        "action": {
                            "type": "otherworldorigins:reset_spell_cooldowns"
                        }
                    },
                    {
                        "type": "origins:target_action",
                        "action": {
                            "type": "origins:apply_effect",
                            "effect": {
                                "effect": "attributeslib:knowledge",
                                "duration": 600,
                                "amplifier": 3,
                                "is_ambient": false,
                                "show_particles": true,
                                "show_icon": true
                            }
                        }
                    }
                ]
            }
        },
        "hud_render": {
            "should_render": true,
            "condition": {
                "type": "origins:resource",
                "resource": "*:*_invoke",
                "compare_to": 0,
                "comparison": ">"
            },
            "sprite_location": "origins:textures/gui/community/spiderkolo/resource_bar_02.png",
            "bar_index": 9
        }
    },
    "sleep": {
        "type": "origins:action_on_wake_up",
        "entity_action": {
            "type": "origins:if_else",
            "condition": {
                "type": "otherworldorigins:player_level",
                "comparison": ">=",
                "compare_to": 20
            },
            "if_action": {
                "type": "origins:modify_resource",
                "resource": "*:*_invoke",
                "modifier": {
                    "operation": "set_total",
                    "value": 0
                }
            }
        }
    }
}
