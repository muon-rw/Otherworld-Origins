{
    "type": "origins:multiple",
    "badges": [
        {
            "type": "origins:tooltip",
            "sprite": "origins:textures/gui/badge/active.png",
            "text": {
                "translate": "origins.gui.badge.active",
                "with": [
                    {
                        "keybind": "key.otherworldorigins.cantrip_three"
                    }
                ]
            }
        }
    ],
    "invoke": {
        "type": "origins:active_self",
        "key": {
            "key": "key.otherworldorigins.cantrip_three"
        },
        "cooldown": 24000,
        "condition": {
            "type": "otherworldorigins:player_level",
            "comparison": ">=",
            "compare_to": 20
        },
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "otherworldorigins:cast_spell",
                    "spell": "irons_spellbooks:shockwave",
                    "power_level": 5,
                    "cast_time": 0,
                    "interrupt_mode": "force_complete"
                },
                {
                    "type": "origins:delay",
                    "ticks": 5,
                    "action": {
                        "type": "otherworldorigins:cast_spell",
                        "spell": "irons_spellbooks:ascension",
                        "power_level": 5,
                        "cast_time": 0,
                        "interrupt_mode": "force_complete"
                    }
                },
                {
                    "type": "origins:delay",
                    "ticks": 10,
                    "action": {
                        "type": "otherworldorigins:cast_spell",
                        "spell": "irons_spellbooks:thunderstorm",
                        "power_level": 5,
                        "cast_time": 0,
                        "interrupt_mode": "force_complete"
                    }
                },
                {
                    "type": "otherworldorigins:area_of_effect_sequential",
                    "radius": 16,
                    "include_self": false,
                    "application_count": 20,
                    "delay_ticks": 3,
                    "bientity_condition": {
                        "type": "origins:or",
                        "inverted": true,
                        "conditions": [
                            {
                                "type": "otherworldorigins:allied"
                            },
                            {
                                "type": "origins:target_condition",
                                "condition": {
                                    "type": "otherworldorigins:is_friendly"
                                }
                            }
                        ]
                    },
                    "bientity_action": {
                        "type": "otherworldorigins:cast_spell",
                        "spell": "irons_spellbooks:lightning_lance",
                        "power_level": 5,
                        "cast_time": 0,
                        "interrupt_mode": "force_complete"
                    }
                }
            ]
        },
        "hud_render": {
            "should_render": true,
            "condition": {
                "type": "origins:resource",
                "resource": "*:*_invoke",
                "compare_to": 0,
                "comparison": ">"
            },
            "sprite_location": "origins:textures/gui/community/spiderkolo/resource_bar_02.png",
            "bar_index": 9
        }
    },
    "sleep": {
        "type": "origins:action_on_wake_up",
        "entity_action": {
            "type": "origins:if_else",
            "condition": {
                "type": "otherworldorigins:player_level",
                "comparison": ">=",
                "compare_to": 20
            },
            "if_action": {
                "type": "origins:modify_resource",
                "resource": "*:*_invoke",
                "modifier": {
                    "operation": "set_total",
                    "value": 0
                }
            }
        }
    }
}