    "stance_cycle": {
        "type": "origins:active_self",
        "key": {
            "key": "key.otherworldorigins.cantrip_two"
        },
        "cooldown": 1,
        "hud_render": {
            "should_render": false
        },
        "entity_action": {
            "type": "origins:if_else_list",
            "actions": [
                {
                    "condition": {
                        "type": "origins:resource",
                        "resource": "*:*_stance",
                        "comparison": "==",
                        "compare_to": 2
