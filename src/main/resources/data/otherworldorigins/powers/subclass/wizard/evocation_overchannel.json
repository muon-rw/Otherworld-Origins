{
    "type": "origins:multiple",
    "badges": [
        {
            "type": "origins:tooltip",
            "sprite": "origins:textures/gui/badge/active.png",
            "text": {
                "translate": "origins.gui.badge.active",
                "with": [
                    {
                        "keybind": "key.otherworldorigins.cantrip_three"
                    }
                ]
            }
        }
    ],
    "charged": {
        "type": "origins:resource",
        "min": 0,
        "max": 1,
        "start_value": 0,
        "hud_render": {
            "should_render": false
        }
    },
    "lockout": {
        "type": "origins:active_self",
        "condition": {
            "type": "origins:constant",
            "value": false
        },
        "entity_action": {
            "type": "origins:nothing"
        },
        "cooldown": 600,
        "hud_render": {
            "should_render": false
        }
    },
    "overchannel_unusable_hp": {
        "type": "origins:active_self",
        "key": {
            "key": "key.otherworldorigins.cantrip_three"
        },
        "cooldown": 0,
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "otherworldorigins:player_level",
                    "comparison": ">=",
                    "compare_to": 20
                },
                {
                    "type": "origins:resource",
                    "resource": "*:*_charged",
                    "comparison": "==",
                    "compare_to": 0
                },
                {
                    "type": "origins:resource",
                    "resource": "*:*_lockout",
                    "comparison": "==",
                    "compare_to": 0
                },
                {
                    "type": "origins:health",
                    "comparison": "<=",
                    "compare_to": 20
                }
            ]
        },
        "entity_action": {
            "type": "otherworldorigins:action_bar_message",
            "message": {
                "translate": "otherworldorigins.overchannel.too_injured",
                "color": "red"
            }
        },
        "hud_render": {
            "should_render": false
        }
    },
    "overchannel_activate": {
        "type": "origins:active_self",
        "key": {
            "key": "key.otherworldorigins.cantrip_three"
        },
        "cooldown": 0,
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "otherworldorigins:player_level",
                    "comparison": ">=",
                    "compare_to": 20
                },
                {
                    "type": "origins:resource",
                    "resource": "*:*_charged",
                    "comparison": "==",
                    "compare_to": 0
                },
                {
                    "type": "origins:resource",
                    "resource": "*:*_lockout",
                    "comparison": "==",
                    "compare_to": 0
                },
                {
                    "type": "origins:health",
                    "comparison": ">",
                    "compare_to": 20
                }
            ]
        },
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:damage",
                    "amount": 20,
                    "damage_type": "minecraft:magic"
                },
                {
                    "type": "origins:modify_resource",
                    "resource": "*:*_charged",
                    "modifier": {
                        "operation": "set_total",
                        "value": 1
                    }
                },
                {
                    "type": "otherworldorigins:action_bar_message",
                    "message": {
                        "translate": "otherworldorigins.overchannel.activated",
                        "color": "yellow"
                    }
                }
            ]
        },
        "hud_render": {
            "should_render": false
        }
    },
    "buff_spell_damage": {
        "type": "origins:modify_damage_dealt",
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_charged",
            "comparison": "==",
            "compare_to": 1
        },
        "damage_condition": {
            "type": "origins:in_tag",
            "tag": "otherworldorigins:is_magic"
        },
        "modifier": {
            "operation": "multiply_total",
            "value": 1
        },
        "self_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:modify_resource",
                    "resource": "*:*_charged",
                    "modifier": {
                        "operation": "set_total",
                        "value": 0
                    }
                },
                {
                    "type": "otherworldorigins:action_bar_message",
                    "message": {
                        "translate": "otherworldorigins.overchannel.triggered",
                        "color": "green"
                    }
                },
                {
                    "type": "origins:modify_resource",
                    "resource": "*:*_lockout",
                    "modifier": {
                        "operation": "add_base_early",
                        "value": 600
                    }
                }
            ]
        }
    }
}
