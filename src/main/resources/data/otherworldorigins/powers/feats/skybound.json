            "tag": "is_fall"
        },
        "modifier": {
            "operation": "multiply_total_multiplicative",
            "value": -1
        },
        "condition": {
            "type": "origins:using_item",
            "item_condition": {
                "type": "origins:or",
                "conditions": [
                    {
                        "type": "origins:ingredient",
                        "ingredient": {
                            "tag": "otherworldorigins:bows"
                        }
                    },
                    {
                        "type": "otherworldorigins:is_bow"
                    }
                ]
            }
        }
    },
    "arrest_fall": {
        "type": "origins:action_over_time",
        "interval": 1,
        "rising_action": {
            "type": "origins:if_else",
