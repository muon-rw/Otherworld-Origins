        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "origins:using_item",
                    "item_condition": {
                        "type": "origins:or",
                        "conditions": [
                            {
                                "type": "origins:ingredient",
                                "ingredient": {
                                    "tag": "otherworldorigins:bows"
                                }
                            },
                            {
                                "type": "otherworldorigins:is_bow"
                            }
                        ]
                    }
                },
                {
                    "type": "origins:on_block",
                    "inverted": true
                }
            ]
        }
    }
