{
    "type": "origins:multiple",
    "shape": {
        "type": "otherworldorigins:shapeshift",
        "entity_type": "alexsmobs:orca",
        "hide_hands": true,
        "allow_tools": false,
        "prevent_equipment": true,
        "prevent_spell_casts": {
            "inverted": true,
            "type": "otherworldorigins:player_level",
            "comparison": ">=",
            "compare_to": 18
        }
    },
    "health": {
        "type": "origins:attribute",
        "modifier": {
            "attribute": "minecraft:generic.max_health",
            "operation": "addition",
            "value": 40
        }
    },
    "damage": {
        "type": "origins:attribute",
        "modifier": {
            "attribute": "minecraft:generic.attack_damage",
            "operation": "addition",
            "value": 14
        }
    },
    "armor": {
        "type": "origins:attribute",
        "modifier": {
            "attribute": "minecraft:generic.armor",
            "operation": "addition",
            "value": 10
        }
    },
    "dolphins_grace": {
        "type": "origins:action_over_time",
        "interval": 20,
        "condition": {
            "type": "origins:or",
            "conditions": [
                {
                    "type": "origins:submerged_in",
                    "fluid": "minecraft:water"
                },
                {
                    "type": "origins:in_block_anywhere",
                    "comparison": ">=",
                    "compare_to": 1,
                    "block_condition": {
                        "type": "origins:fluid",
                        "fluid_condition": {
                            "type": "origins:in_tag",
                            "tag": "minecraft:water"
                        }
                    }
                }
            ]
        },
        "entity_action": {
            "type": "origins:apply_effect",
            "effect": {
                "effect": "minecraft:dolphins_grace",
                "duration": 250,
                "amplifier": 0,
                "is_ambient": true,
                "show_particles": false,
                "show_icon": false
            }
        },
        "falling_action": {
            "type": "origins:if_else",
            "condition": {
                "type": "origins:status_effect",
                "effect": "minecraft:dolphins_grace",
                "max_duration": 250
            },
            "if_action": {
                "type": "origins:clear_effect",
                "effect": "minecraft:dolphins_grace"
            }
        }
    },
    "land_slowness": {
        "type": "origins:action_over_time",
        "interval": 20,
        "condition": {
            "inverted": true,
            "type": "origins:or",
            "conditions": [
                {
                    "type": "origins:submerged_in",
                    "fluid": "minecraft:water"
                },
                {
                    "type": "origins:in_block_anywhere",
                    "comparison": ">=",
                    "compare_to": 1,
                    "block_condition": {
                        "type": "origins:fluid",
                        "fluid_condition": {
                            "type": "origins:in_tag",
                            "tag": "minecraft:water"
                        }
                    }
                }
            ]
        },
        "entity_action": {
            "type": "origins:apply_effect",
            "effect": {
                "effect": "minecraft:slowness",
                "duration": 250,
                "amplifier": 9,
                "is_ambient": true,
                "show_particles": false,
                "show_icon": false
            }
        },
        "falling_action": {
            "type": "origins:if_else",
            "condition": {
                "type": "origins:status_effect",
                "effect": "minecraft:slowness",
                "max_duration": 250
            },
            "if_action": {
                "type": "origins:clear_effect",
                "effect": "minecraft:slowness"
            }
        }
    },
    "cleanup_effects": {
        "type": "origins:action_on_callback",
        "entity_action_lost": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:clear_effect",
                    "effect": "minecraft:dolphins_grace"
                },
                {
                    "type": "origins:clear_effect",
                    "effect": "minecraft:slowness"
                }
            ]
        }
    },
    "prevent_death": {
        "type": "origins:prevent_death",
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:heal",
                    "amount": 1000
                },
                {
                    "type": "origins:execute_command",
                    "command": "origin set @s otherworldorigins:wildshape origins:empty"
                }
            ]
        }
    },
    "timer": {
        "type": "origins:resource",
        "min": 0,
        "max": 6000,
        "start_value": 6000,
        "min_action": {
            "type": "origins:execute_command",
            "command": "origin set @s otherworldorigins:wildshape origins:empty"
        },
        "hud_render": {
            "should_render": true,
            "sprite_location": "origins:textures/gui/community/huang/resource_bar_02.png",
            "bar_index": 5,
            "condition": {
                "type": "origins:resource",
                "resource": "*:*_timer",
                "comparison": ">",
                "compare_to": 0
            }
        }
    },
    "tick_timer": {
        "type": "origins:action_over_time",
        "interval": 20,
        "entity_action": {
            "type": "origins:modify_resource",
            "resource": "*:*_timer",
            "modifier": {
                "operation": "add_base_early",
                "value": -20
            }
        }
    },
    "charge_callback": {
        "type": "origins:action_on_callback",
        "entity_action_gained": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:heal",
                    "amount": 1000
                },
                {
                    "type": "origins:modify_resource",
                    "resource": "otherworldorigins:class/druid/wildshape_wildshape_charges",
                    "modifier": {
                        "operation": "add_base_early",
                        "value": -1
                    }
                },
                {
                    "type": "origins:modify_resource",
                    "resource": "otherworldorigins:class/druid/wildshape_wildshape_gate",
                    "modifier": {
                        "operation": "set_total",
                        "value": 0
                    }
                }
            ]
        }
    }
