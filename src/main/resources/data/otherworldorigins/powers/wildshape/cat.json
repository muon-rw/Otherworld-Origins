{
    "type": "origins:multiple",
    "hidden": true,
    "shape": {
        "type": "otherworldorigins:shapeshift",
        "entity_type": "minecraft:cat",
        "hide_hands": true,
        "allow_tools": false,
        "prevent_equipment": true,
        "prevent_spell_casts": {
            "inverted": true,
            "type": "otherworldorigins:player_level",
            "comparison": ">=",
            "compare_to": 18
        },
        "attack_range": 1.5,
        "attacks": [
            { "hitbox": "FORWARD_BOX", "angle": 40, "damage_multiplier": 1.0, "upswing": 0.2 },
            { "hitbox": "FORWARD_BOX", "angle": 50, "damage_multiplier": 1.0, "upswing": 0.2 }
        ]
    },
    "attributes": {
        "type": "origins:attribute",
        "modifiers": [
            {
                "name": "Wildshape max health",
                "attribute": "minecraft:generic.max_health",
                "operation": "addition",
                "value": -10
            },
            {
                "name": "Wildshape attack damage",
                "attribute": "minecraft:generic.attack_damage",
                "value": 2,
                "operation": "addition"
            },
            {
                "name": "Wildshape attack speed",
                "attribute": "minecraft:generic.attack_speed",
                "value": -0.9,
                "operation": "addition"
            },
            {
                "name": "Wildshape movement speed",
                "attribute": "minecraft:generic.movement_speed",
                "value": 0.3,
                "operation": "multiply_base"
            }
        ]
    },
    "wall_climb": {
        "type": "origins:climbing",
        "condition": {
            "type": "origins:collided_horizontally"
        },
        "allow_holding": true,
        "hold_condition": {
            "type": "origins:collided_horizontally"
        }
    },
    "stealth_cooldown": {
        "type": "origins:resource",
        "min": 0,
        "max": 60,
        "start_value": 0,
        "hud_render": {
            "should_render": true,
            "sprite_location": "origins:textures/gui/community/huang/resource_bar_02.png",
            "bar_index": 1,
            "condition": {
                "type": "origins:resource",
                "resource": "*:*_stealth_cooldown",
                "comparison": ">",
                "compare_to": 0
            }
        }
    },
    "stealth_tick_cooldown": {
        "type": "origins:action_over_time",
        "interval": 1,
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_stealth_cooldown",
            "comparison": ">",
            "compare_to": 0
        },
        "entity_action": {
            "type": "origins:change_resource",
            "resource": "*:*_stealth_cooldown",
            "change": -1
        }
    },
    "stealth_break_on_attack": {
        "type": "origins:modify_damage_dealt",
        "modifier": {
            "operation": "multiply_total",
            "value": 0.5
        },
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "origins:invisible"
                },
                {
                    "type": "origins:sneaking"
                },
                {
                    "type": "origins:resource",
                    "resource": "*:*_stealth_cooldown",
                    "comparison": "==",
                    "compare_to": 0
                }
            ]
        },
        "self_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:clear_effect",
                    "effect": "minecraft:invisibility"
                },
                {
                    "type": "origins:execute_command",
                    "command": "scale reset pehkui:visibility @s"
                },
                {
                    "type": "origins:play_sound",
                    "sound": "minecraft:entity.player.attack.sweep",
                    "category": "players"
                },
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_stealth_cooldown",
                    "change": 60
                }
            ]
        }
    },
    "shadow_step": {
        "type": "origins:action_over_time",
        "interval": 2,
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "origins:sneaking"
                },
                {
                    "type": "origins:resource",
                    "resource": "*:*_stealth_cooldown",
                    "comparison": "==",
                    "compare_to": 0
                }
            ]
        },
        "rising_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:execute_command",
                    "command": "scale set pehkui:visibility 0 @s"
                },
                {
                    "type": "origins:play_sound",
                    "sound": "minecraft:entity.player.breath",
                    "volume": 0.2,
                    "pitch": 1.3,
                    "category": "players"
                },
                {
                    "type": "origins:area_of_effect",
                    "radius": 32,
                    "bientity_action": {
                        "type": "origins:target_action",
                        "action": {
                            "type": "origins:execute_command",
                            "command": "data modify entity @s AngryTime set value 0"
                        }
                    },
                    "bientity_condition": {
                        "type": "origins:invert",
                        "condition": {
                            "type": "origins:attack_target"
                        }
                    }
                }
            ]
        },
        "entity_action": {
            "type": "origins:apply_effect",
            "effect": {
                "effect": "minecraft:invisibility",
                "duration": 200,
                "amplifier": 0,
                "is_ambient": true,
                "show_icon": false,
                "show_particles": false
            }
        },
        "falling_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:clear_effect",
                    "effect": "minecraft:invisibility"
                },
                {
                    "type": "origins:execute_command",
                    "command": "scale reset pehkui:visibility @s"
                }
            ]
        }
    },
    "no_fall_damage": {
        "type": "origins:modify_damage_taken",
        "damage_condition": {
            "type": "origins:in_tag",
            "tag": "is_fall"
        },
        "modifier": {
            "operation": "multiply_total_multiplicative",
            "value": -1
        }
    },
    "prevent_death": {
        "type": "origins:prevent_death",
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:heal",
                    "amount": 1000
                },
                {
                    "type": "origins:execute_command",
                    "command": "origin set @s otherworldorigins:wildshape origins:empty"
                }
            ]
        }
    },
    "timer": {
        "type": "origins:resource",
        "min": 0,
        "max": 6000,
        "start_value": 6000,
        "min_action": {
            "type": "origins:execute_command",
            "command": "origin set @s otherworldorigins:wildshape origins:empty"
        },
        "hud_render": {
            "should_render": true,
            "sprite_location": "origins:textures/gui/community/huang/resource_bar_02.png",
            "bar_index": 7,
            "condition": {
                "type": "origins:resource",
                "resource": "*:*_timer",
                "comparison": ">",
                "compare_to": 0
            }
        }
    },
    "tick_timer": {
        "type": "origins:action_over_time",
        "interval": 20,
        "entity_action": {
            "type": "origins:modify_resource",
            "resource": "*:*_timer",
            "modifier": {
                "operation": "add_base_early",
                "value": -20
            }
        }
    },
    "charge_callback": {
        "type": "origins:action_on_callback",
        "entity_action_gained": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:play_sound",
                    "sound": "minecraft:entity.evoker.prepare_summon",
                    "pitch": 0.7
                },
                {
                    "type": "origins:spawn_particles",
                    "particle": "minecraft:flash",
                    "count": 1,
                    "force": true
                },
                {
                    "type": "origins:play_sound",
                    "sound": "minecraft:entity.cat.ambient"
                },
                {
                    "type": "origins:heal",
                    "amount": 1000
                },
                {
                    "type": "origins:modify_resource",
                    "resource": "otherworldorigins:class/druid/wildshape_wildshape_charges",
                    "modifier": {
                        "operation": "add_base_early",
                        "value": -1
                    }
                },
                {
                    "type": "origins:modify_resource",
                    "resource": "otherworldorigins:class/druid/wildshape_wildshape_gate",
                    "modifier": {
                        "operation": "set_total",
                        "value": 0
                    }
                }
            ]
        }
    }
}
