{
    "type": "origins:multiple",
    "badges": [
        {
            "type": "origins:tooltip",
            "sprite": "origins:textures/gui/badge/info.png",
            "text": {
                "translate": "otherworldorigins.gui.badge.wildshape_forms"
            }
        },
        {
            "type": "origins:tooltip",
            "sprite": "origins:textures/gui/badge/info.png",
            "text": {
                "translate": "otherworldorigins.gui.badge.wildshape_forms_exit",
                "with": [
                    {
                        "keybind": "key.otherworldorigins.cantrip_three"
                    },
                    {
                        "keybind": "key.sneak"
                    }
                ]
            }
        },
        {
            "type": "origins:tooltip",
            "sprite": "origins:textures/gui/badge/arrow_up.png",
            "text": {
                "translate": "otherworldorigins.gui.badge.wildshape_uses_per_level"
            }
        },
        {
            "type": "origins:tooltip",
            "sprite": "origins:textures/gui/badge/arrow_up.png",
            "text": {
                "translate": "otherworldorigins.gui.badge.wildshape_spellcasting"
            }
        }
    ],
    "wildshape_gate": {
        "type": "origins:resource",
        "min": 0,
        "max": 1,
        "start_value": 0,
        "hud_render": {
            "should_render": false
        }
    },
    "wildshape_charges": {
        "type": "otherworldorigins:leveled_resource",
        "min": 0,
        "stepped_max": {
            "start": 2,
            "increment": 1,
            "gap": 4,
            "max_steps": 4
        },
        "start_value": 999,
        "restore_on_levelup": true,
        "hud_render": {
            "should_render": true,
            "sprite_location": "origins:textures/gui/community/spiderkolo/resource_bar_03.png",
            "bar_index": 6
        }
    },
    "charge_regen": {
        "type": "origins:action_over_time",
        "interval": 6000,
        "entity_action": {
            "type": "origins:modify_resource",
            "resource": "*:*_wildshape_charges",
            "modifier": {
                "operation": "add_base_early",
                "value": 1
            }
        }
    },
    "sleep_restore": {
        "type": "origins:action_on_wake_up",
        "entity_action": {
            "type": "origins:modify_resource",
            "resource": "*:*_wildshape_charges",
            "modifier": {
                "operation": "set_total",
                "value": 999999
            }
        }
    },
    "enter_wildshape": {
        "type": "origins:active_self",
        "key": {
            "key": "key.otherworldorigins.cantrip_three"
        },
        "cooldown": 20,
        "hud_render": {
            "should_render": false
        },
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "otherworldorigins:any_on_layer",
                    "layer": "otherworldorigins:wildshape",
                    "inverted": true
                },
                {
                    "type": "origins:resource",
                    "resource": "*:*_wildshape_charges",
                    "comparison": ">",
                    "compare_to": 0
                }
            ]
        },
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:modify_resource",
                    "resource": "*:*_wildshape_gate",
                    "modifier": {
                        "operation": "set_total",
                        "value": 1
                    }
                },
                {
                    "type": "otherworldorigins:prompt_layer_selection",
                    "layers": ["otherworldorigins:wildshape"]
                }
            ]
        }
    },
    "cantrip_held": {
        "type": "origins:resource",
        "min": 0,
        "max": 1,
        "start_value": 0,
        "hud_render": {
            "should_render": false
        }
    },
    "exit_meter": {
        "type": "origins:resource",
        "min": 0,
        "max": 60,
        "start_value": 0,
        "hud_render": {
            "should_render": true,
            "sprite_location": "origins:textures/gui/community/spiderkolo/resource_bar_03.png",
            "bar_index": 9,
            "condition": {
                "type": "origins:resource",
                "resource": "*:*_exit_meter",
                "comparison": ">",
                "compare_to": 0
            }
        },
        "max_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:execute_command",
                    "command": "origin set @s otherworldorigins:wildshape origins:empty"
                },
                {
                    "type": "origins:modify_resource",
                    "resource": "*:*_cantrip_held",
                    "modifier": {
                        "operation": "set_total",
                        "value": 0
                    }
                }
            ]
        }
    },
    "exit_charge": {
        "type": "origins:action_over_time",
        "interval": 1,
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "otherworldorigins:any_on_layer",
                    "layer": "otherworldorigins:wildshape"
                },
                {
                    "type": "origins:sneaking"
                },
                {
                    "type": "origins:resource",
                    "resource": "*:*_cantrip_held",
                    "comparison": ">=",
                    "compare_to": 1
                }
            ]
        },
        "entity_action": {
            "type": "origins:modify_resource",
            "resource": "*:*_exit_meter",
            "modifier": {
                "operation": "add_base_early",
                "value": 1
            }
        }
    },
    "exit_drain": {
        "type": "origins:action_over_time",
        "interval": 1,
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "otherworldorigins:any_on_layer",
                    "layer": "otherworldorigins:wildshape"
                },
                {
                    "type": "origins:resource",
                    "resource": "*:*_exit_meter",
                    "comparison": ">",
                    "compare_to": 0
                },
                {
                    "type": "origins:or",
                    "conditions": [
                        {
                            "type": "origins:sneaking",
                            "inverted": true
                        },
                        {
                            "type": "origins:resource",
                            "resource": "*:*_cantrip_held",
                            "comparison": "==",
                            "compare_to": 0
                        }
                    ]
                }
            ]
        },
        "entity_action": {
            "type": "origins:modify_resource",
            "resource": "*:*_exit_meter",
            "modifier": {
                "operation": "add_base_early",
                "value": -2
            }
        }
    },
    "wildshape_state_watcher": {
        "type": "origins:action_over_time",
        "interval": 1,
        "condition": {
            "type": "otherworldorigins:any_on_layer",
            "layer": "otherworldorigins:wildshape"
        },
        "falling_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:modify_resource",
                    "resource": "*:*_cantrip_held",
                    "modifier": {
                        "operation": "set_total",
                        "value": 0
                    }
                },
                {
                    "type": "origins:modify_resource",
                    "resource": "*:*_exit_meter",
                    "modifier": {
                        "operation": "set_total",
                        "value": 0
                    }
                }
            ]
        }
    },
    "reset_gate_on_join": {
        "type": "origins:action_on_callback",
        "entity_action_added": {
            "type": "origins:modify_resource",
            "resource": "*:*_wildshape_gate",
            "modifier": {
                "operation": "set_total",
                "value": 0
            }
        }
    },
    "capstone": {
        "type": "origins:action_over_time",
        "interval": 20,
        "condition": {
            "type": "otherworldorigins:player_level",
            "comparison": ">=",
            "compare_to": 20
        },
        "entity_action": {
            "type": "origins:modify_resource",
            "resource": "*:*_wildshape_charges",
            "modifier": {
                "operation": "set_total",
                "value": 999999
            }
        }
    },
    "wildshape_health_scaling": {
        "type": "otherworldorigins:leveled_attribute",
        "attribute": "minecraft:generic.max_health",
        "operation": "addition",
        "value_per_level": 2.0,
        "starting_value": 2.0,
        "update_health": false,
        "condition": {
            "type": "otherworldorigins:any_on_layer",
            "layer": "otherworldorigins:wildshape"
        }
    },
    "wildshape_damage_scaling": {
        "type": "otherworldorigins:leveled_attribute",
        "attribute": "minecraft:generic.attack_damage",
        "operation": "addition",
        "value_per_level": 0.4,
        "starting_value": 0.4,
        "condition": {
            "type": "otherworldorigins:any_on_layer",
            "layer": "otherworldorigins:wildshape"
        }
    },
    "wildshape_armor_scaling": {
        "type": "otherworldorigins:leveled_attribute",
        "attribute": "minecraft:generic.armor",
        "operation": "addition",
        "value_per_level": 0.2,
        "starting_value": 0.2,
        "condition": {
            "type": "otherworldorigins:any_on_layer",
            "layer": "otherworldorigins:wildshape"
        }
    }
}
